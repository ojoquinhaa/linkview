{
  "name": "urlsimples",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "db:generate": "pnpm --filter @urlsimples/db db:generate",
    "db:migrate": "pnpm --filter @urlsimples/db db:migrate",
    "db:push": "pnpm --filter @urlsimples/db db:push",
    "db:studio": "pnpm --filter @urlsimples/db db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
