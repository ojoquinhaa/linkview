# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
SYSTEM_DOMAIN="lnkv.com.br"

# Auth (Better Auth)
BETTER_AUTH_SECRET="change-me-min-16-chars"
BETTER_AUTH_URL="http://localhost:3000"
# Browser-facing app URL used by the auth client. MUST be set in production
# (e.g. https://app.linkview.com.br) or login/signup calls hit localhost.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Billing (Asaas)
ASAAS_API_KEY=""
ASAAS_WEBHOOK_TOKEN=""
# Optional. Defaults to production. Sandbox: https://sandbox.asaas.com/api/v3
ASAAS_API_URL=""

# Cron (Vercel scheduled jobs) — required for trial expiry, past-due cutoff,
# and data-retention purge. Vercel auto-sends "Authorization: Bearer $CRON_SECRET"
# to scheduled invocations; the job rejects (401) without it. Generate a random
# value, e.g. `openssl rand -hex 32`, and set it in both .env and Vercel.
CRON_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
# Verified sender. Defaults to "linkview <nao-responda@linkview.com.br>".
EMAIL_FROM=""

# Cloudflare KV sync (web app)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_KV_NAMESPACE_ID=""
CLOUDFLARE_API_TOKEN=""

# Cloudflare R2 image uploads (Open Graph share images)
# R2_ACCOUNT_ID is the same Cloudflare account id as above.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public base URL of the bucket (r2.dev domain or a custom domain).
R2_PUBLIC_URL=""

# Realtime dashboard push (Upstash Redis pub/sub)
# Use the TCP connection string (rediss://default:<token>@<host>:6379), NOT the
# REST URL — ioredis pub/sub needs a raw Redis connection. Leave empty to
# disable live updates (clicks still record).
REDIS_URL=""

# Observability
SENTRY_DSN=""

# Privacy: salt for hashing visitor IPs (min 16 chars)
IP_HASH_SALT="change-me-min-16-chars"
