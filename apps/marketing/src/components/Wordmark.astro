---
// linkview brand lockup: the eye-in-chain mark leading the Bricolage wordmark,
// the same lockup used in the app (apps/web components/wordmark).
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<span
  class={`inline-flex items-center font-display text-[1.35rem] font-semibold tracking-tight text-ink ${className}`}
>
  <img src="/logo.png" alt="" aria-hidden="true" class="mr-[0.42em] h-[0.92em] w-auto" />
  linkview
</span>
