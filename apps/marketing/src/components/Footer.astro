---
import { APP_URL, LOGIN_URL, REGISTER_URL, SHORT_DOMAIN } from "@/lib/site";
import Wordmark from "./Wordmark.astro";

const cols = [
  {
    title: "Produto",
    links: [
      { label: "Recursos", href: "#recursos" },
      { label: "Preço", href: "#preco" },
      { label: "Entrar", href: LOGIN_URL },
      { label: "Criar conta", href: REGISTER_URL },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Termos de uso", href: `${APP_URL}/termos` },
      { label: "Privacidade", href: `${APP_URL}/privacidade` },
    ],
  },
];
---

<footer class="border-t border-line">
  <div
    class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:px-8 md:grid-cols-[1.4fr_1fr_1fr]"
  >
    <div>
      <Wordmark />
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-muted">
        Cada clique conta. Links, QR Codes e campanhas rastreáveis, em português
        e em reais.
      </p>
      <p class="mt-4 font-mono text-xs text-muted">{SHORT_DOMAIN}</p>
    </div>

    {
      cols.map((col) => (
        <nav aria-label={col.title}>
          <h2 class="text-sm font-semibold text-ink">{col.title}</h2>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="rounded text-sm text-ink-soft transition-colors hover:text-accent-deep"
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="border-t border-line">
    <div
      class="mx-auto flex max-w-6xl flex-col gap-2 px-5 py-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between sm:px-8"
    >
      <p>© 2026 Linkview. Todos os direitos reservados.</p>
      <p>Feito no Brasil.</p>
    </div>
  </div>
</footer>
